<Window
x:Class="Bloomdo.Client.UI.MainWindow"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:shad="clr-namespace:ShadUI;assembly=ShadUI"
xmlns:viewModels="clr-namespace:Bloomdo.Client.Application.ViewModels;assembly=Bloomdo.Client.Application"
Title="Bloomdo"
d:DesignHeight="450"
d:DesignWidth="800"
x:DataType="viewModels:ShellViewModel"
mc:Ignorable="d">

	<Panel>
		<ContentControl Content="{Binding CurrentViewModel}" />
		<shad:DialogHost x:Name="DialogHostControl" />
		<shad:ToastHost x:Name="ToastHostControl" />
	</Panel>

</Window>