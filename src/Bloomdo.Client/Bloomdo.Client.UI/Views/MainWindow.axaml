<Window
x:Class="Bloomdo.UI.MainWindow"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:viewModels1="clr-namespace:Bloomdo.Application.ViewModels;assembly=Bloomdo.Client.Application"
Title="Bloomdo"
d:DesignHeight="450"
d:DesignWidth="800"
x:DataType="viewModels1:ShellViewModel"
mc:Ignorable="d">

	<Design.DataContext>
		<viewModels1:ShellViewModel />
	</Design.DataContext>
	<ContentControl Content="{Binding CurrentViewModel}" />

</Window>