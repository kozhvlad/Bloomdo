<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:viewModels1="clr-namespace:Bloomdo.Application.ViewModels;assembly=Bloomdo.Client.Application"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="Bloomdo.UI.ShellView"
			 x:CompileBindings="True"
			 x:DataType="viewModels1:ShellViewModel">

	<ContentControl Content="{Binding CurrentViewModel, Mode=OneWay}" />

</UserControl>