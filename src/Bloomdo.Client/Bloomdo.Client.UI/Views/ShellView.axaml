<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:shad="clr-namespace:ShadUI;assembly=ShadUI"
			 xmlns:viewModels="clr-namespace:Bloomdo.Client.Application.ViewModels;assembly=Bloomdo.Client.Application"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="Bloomdo.Client.UI.ShellView"
			 x:CompileBindings="True"
			 x:DataType="viewModels:ShellViewModel">

	<Panel>
		<ContentControl Content="{Binding CurrentViewModel, Mode=OneWay}" />
		<shad:DialogHost x:Name="DialogHostControl" />
		<shad:ToastHost x:Name="ToastHostControl" />

		<!-- Custom dialog overlay (works on Android without Window) -->
		<Panel IsVisible="{Binding IsOverlayOpen}">
			<Button Background="#CC000000"
					HorizontalAlignment="Stretch"
					VerticalAlignment="Stretch"
					HorizontalContentAlignment="Stretch"
					VerticalContentAlignment="Stretch"
					Padding="0" BorderThickness="0"
					CornerRadius="0"
					Command="{Binding CloseOverlayCommand}">
				<Panel/>
			</Button>
			<ContentControl Content="{Binding OverlayContent}"
							HorizontalAlignment="Center"
							VerticalAlignment="Center"
							MaxWidth="400"
							Margin="20"/>
		</Panel>
	</Panel>

</UserControl>