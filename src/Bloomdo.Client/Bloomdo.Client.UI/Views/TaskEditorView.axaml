<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shad="clr-namespace:ShadUI;assembly=ShadUI"
             xmlns:converters="clr-namespace:Bloomdo.Client.UI.Converters"
             xmlns:vm="clr-namespace:Bloomdo.Client.Application.ViewModels;assembly=Bloomdo.Client.Application"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             x:DataType="vm:TaskEditorViewModel"
             x:Class="Bloomdo.Client.UI.TaskEditorView">

    <UserControl.Resources>
        <converters:BlockTypeColorConverter x:Key="ColorConverter"/>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacity"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.PulseLock">
            <Style.Animations>
                <Animation Duration="0:0:2" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.65"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1.0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource Brush.Background}">

        <!-- Header -->
        <Grid ColumnDefinitions="Auto,*" Margin="16,16,16,0">
            <Button Command="{Binding CancelCommand}" Background="Transparent"
                    BorderThickness="0" Padding="8" Cursor="Hand">
                <PathIcon Data="{StaticResource arrow_left_regular}" Width="20" Height="20"
                          Foreground="{DynamicResource Brush.Foreground}"/>
            </Button>
            <TextBlock Grid.Column="1" Text="{Binding PageTitle}"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource Brush.Foreground}"
                       VerticalAlignment="Center" Margin="12,0,0,0"/>
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Margin="0,8,0,0">
            <StackPanel Margin="20,0,20,24" Spacing="14">

                <!-- Live Preview Card -->
                <Border CornerRadius="16" Padding="14,12"
                        Background="{Binding TaskColor, Converter={StaticResource ColorConverter}}">
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Width="44" Height="44" CornerRadius="22"
                                Background="#33FFFFFF" Margin="0,0,12,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding PreviewIcon}"
                                       FontFamily="{StaticResource EmojiFont}"
                                       FontSize="20"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{Binding PreviewTitle}"
                                       FontSize="16" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Background="#33FFFFFF" CornerRadius="6" Padding="6,2">
                                    <TextBlock Text="{Binding PreviewSubtitle}"
                                               FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Emoji Picker -->
                <Panel>
                <shad:Card Padding="14" Background="{DynamicResource Brush.Card}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Task Icon" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundColor}"/>

                        <Button Command="{Binding ToggleEmojiPickerCommand}"
                                Background="#15FFFFFF" CornerRadius="12"
                                Padding="10,8" BorderThickness="0" Cursor="Hand"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding TaskIcon}"
                                           FontFamily="{StaticResource EmojiFont}"
                                           FontSize="24" VerticalAlignment="Center"/>
                                <TextBlock Text="Change icon"
                                           FontSize="12" Opacity="0.6"
                                           Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
                                <PathIcon Data="{x:Static shad:Icons.ChevronDown}" Width="12" Height="12"
                                          Foreground="{DynamicResource ForegroundColor}" Opacity="0.4"/>
                            </StackPanel>
                        </Button>

                        <!-- Emoji grid -->
                        <Border IsVisible="{Binding IsEmojiPickerOpen}"
                                Background="#0AFFFFFF" CornerRadius="12" Padding="8">
                            <ItemsControl ItemsSource="{x:Static vm:TaskEditorViewModel.AvailableEmojis}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Button Classes="Ghost" Padding="4" Margin="2"
                                                Width="40" Height="40"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                Command="{Binding ((vm:TaskEditorViewModel)DataContext).SelectEmojiCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="{Binding}"
                                                       FontFamily="{StaticResource EmojiFont}"
                                                       FontSize="20"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </shad:Card>
                <Border Classes="PulseLock" IsVisible="{Binding !CanCustomizeEmoji}"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,-4,-4,0" Width="28" Height="28" CornerRadius="14"
                        IsHitTestVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="#FFD54F" Offset="0"/>
                            <GradientStop Color="#FF9800" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="🔒" FontFamily="{StaticResource EmojiFont}" FontSize="12"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                </Panel>

                <!-- Task Name -->
                <shad:Card Padding="14" Background="{DynamicResource Brush.Card}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Task Name" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundColor}"/>
                        <TextBox Text="{Binding TaskTitle}"
                                 Watermark="e.g. Read 30 min, Meditate, Exercise..."
                                 FontSize="14"/>
                    </StackPanel>
                </shad:Card>

                <!-- Description -->
                <shad:Card Padding="14" Background="{DynamicResource Brush.Card}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Description" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundColor}"/>
                        <TextBox Text="{Binding TaskDescription}"
                                 Watermark="Add details (optional)"
                                 FontSize="13" AcceptsReturn="True"
                                 MaxHeight="80"/>
                    </StackPanel>
                </shad:Card>

                <!-- Task Type -->
                <shad:Card Padding="14" Background="{DynamicResource Brush.Card}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Task Type" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundColor}"/>
                        <Grid ColumnDefinitions="*,8,*" RowDefinitions="Auto,8,Auto,8,Auto">
                            <Button Grid.Column="0" Grid.Row="0" Padding="10"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    CornerRadius="12"
                                    Opacity="{Binding IsTimerType, Converter={StaticResource BoolToOpacity}}"
                                    Command="{Binding SelectTaskTypeCommand}"
                                    CommandParameter="Timer">
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                    <TextBlock Text="⏱" FontFamily="{StaticResource EmojiFont}" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="Timer" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" Grid.Row="0" Padding="10"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    CornerRadius="12"
                                    Opacity="{Binding IsCountType, Converter={StaticResource BoolToOpacity}}"
                                    Command="{Binding SelectTaskTypeCommand}"
                                    CommandParameter="Count">
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                    <TextBlock Text="📊" FontFamily="{StaticResource EmojiFont}" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="Count" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="0" Grid.Row="2" Padding="10"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    CornerRadius="12"
                                    Opacity="{Binding IsStepsType, Converter={StaticResource BoolToOpacity}}"
                                    Command="{Binding SelectTaskTypeCommand}"
                                    CommandParameter="Steps">
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                    <TextBlock Text="🚶" FontFamily="{StaticResource EmojiFont}" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="Steps" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" Grid.Row="2" Padding="10"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    CornerRadius="12"
                                    Opacity="{Binding IsCheckboxType, Converter={StaticResource BoolToOpacity}}"
                                    Command="{Binding SelectTaskTypeCommand}"
                                    CommandParameter="Checkbox">
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                    <TextBlock Text="✅" FontFamily="{StaticResource EmojiFont}" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="Checkbox" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="3" Padding="10"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    CornerRadius="12"
                                    Opacity="{Binding IsPhotoVerificationType, Converter={StaticResource BoolToOpacity}}"
                                    Command="{Binding SelectTaskTypeCommand}"
                                    CommandParameter="PhotoVerification">
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                    <TextBlock Text="📷" FontFamily="{StaticResource EmojiFont}" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="Photo Verification" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </shad:Card>

                <!-- Duration (Timer type) -->
                <shad:Card Padding="14" Background="{DynamicResource Brush.Card}"
                           IsVisible="{Binding IsTimerType}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Duration" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundColor}"/>
                        <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Center">
                            <Button Grid.Column="0" Classes="Ghost" Padding="8"
                                    Width="44" Height="44" CornerRadius="22"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="#15FFFFFF"
                                    Command="{Binding DecrementDurationCommand}">
                                <PathIcon Data="{x:Static shad:Icons.Minus}" Width="14" Height="14"
                                          Foreground="{DynamicResource ForegroundColor}"/>
                            </Button>
                            <Border Grid.Column="1" CornerRadius="12" Padding="20,8"
                                    Background="#0AFFFFFF" MinWidth="100" Margin="16,0"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TaskDurationMinutes, StringFormat='{}{0} min'}"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="{DynamicResource ForegroundColor}"
                                           HorizontalAlignment="Center"/>
                            </Border>
                            <Button Grid.Column="2" Classes="Ghost" Padding="8"
                                    Width="44" Height="44" CornerRadius="22"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="#15FFFFFF"
                                    Command="{Binding IncrementDurationCommand}">
                                <PathIcon Data="{x:Static shad:Icons.Cross}" Width="14" Height="14"
                                          Foreground="{DynamicResource ForegroundColor}">
                                    <PathIcon.RenderTransform>
                                        <RotateTransform Angle="45"/>
                                    </PathIcon.RenderTransform>
                                </PathIcon>
                            </Button>
                        </Grid>
                    </StackPanel>
                </shad:Card>

                <!-- Target Count (Count type) -->
                <shad:Card Padding="14" Background="{DynamicResource Brush.Card}"
                           IsVisible="{Binding IsCountType}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Target Count" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundColor}"/>
                        <TextBlock Text="How many times do you want to complete this?"
                                   FontSize="12" Opacity="0.5" Foreground="{DynamicResource ForegroundColor}"/>
                        <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Center">
                            <Button Grid.Column="0" Classes="Ghost" Padding="8"
                                    Width="44" Height="44" CornerRadius="22"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="#15FFFFFF"
                                    Command="{Binding DecrementTargetCountCommand}">
                                <PathIcon Data="{x:Static shad:Icons.Minus}" Width="14" Height="14"
                                          Foreground="{DynamicResource ForegroundColor}"/>
                            </Button>
                            <Border Grid.Column="1" CornerRadius="12" Padding="20,8"
                                    Background="#0AFFFFFF" MinWidth="100" Margin="16,0"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TaskTargetCount}"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="{DynamicResource ForegroundColor}"
                                           HorizontalAlignment="Center"/>
                            </Border>
                            <Button Grid.Column="2" Classes="Ghost" Padding="8"
                                    Width="44" Height="44" CornerRadius="22"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="#15FFFFFF"
                                    Command="{Binding IncrementTargetCountCommand}">
                                <PathIcon Data="{x:Static shad:Icons.Cross}" Width="14" Height="14"
                                          Foreground="{DynamicResource ForegroundColor}">
                                    <PathIcon.RenderTransform>
                                        <RotateTransform Angle="45"/>
                                    </PathIcon.RenderTransform>
                                </PathIcon>
                            </Button>
                        </Grid>
                    </StackPanel>
                </shad:Card>

                <!-- Target Steps (Steps type) -->
                <shad:Card Padding="14" Background="{DynamicResource Brush.Card}"
                           IsVisible="{Binding IsStepsType}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Step Goal" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundColor}"/>
                        <TextBlock Text="How many steps is your daily goal?"
                                   FontSize="12" Opacity="0.5" Foreground="{DynamicResource ForegroundColor}"/>
                        <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Center">
                            <Button Grid.Column="0" Classes="Ghost" Padding="8"
                                    Width="44" Height="44" CornerRadius="22"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="#15FFFFFF"
                                    Command="{Binding DecrementTargetStepsCommand}">
                                <PathIcon Data="{x:Static shad:Icons.Minus}" Width="14" Height="14"
                                          Foreground="{DynamicResource ForegroundColor}"/>
                            </Button>
                            <Border Grid.Column="1" CornerRadius="12" Padding="20,8"
                                    Background="#0AFFFFFF" MinWidth="120" Margin="16,0"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TaskTargetCount, StringFormat='{}{0} steps'}"
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="{DynamicResource ForegroundColor}"
                                           HorizontalAlignment="Center"/>
                            </Border>
                            <Button Grid.Column="2" Classes="Ghost" Padding="8"
                                    Width="44" Height="44" CornerRadius="22"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="#15FFFFFF"
                                    Command="{Binding IncrementTargetStepsCommand}">
                                <PathIcon Data="{x:Static shad:Icons.Cross}" Width="14" Height="14"
                                          Foreground="{DynamicResource ForegroundColor}">
                                    <PathIcon.RenderTransform>
                                        <RotateTransform Angle="45"/>
                                    </PathIcon.RenderTransform>
                                </PathIcon>
                            </Button>
                        </Grid>
                    </StackPanel>
                </shad:Card>

                <!-- Photo Verification Template -->
                <shad:Card Padding="14" Background="{DynamicResource Brush.Card}"
                           IsVisible="{Binding IsPhotoVerificationType}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Verification Template" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundColor}"/>
                        <TextBlock Text="AI will check the photo against this criteria"
                                   FontSize="12" Opacity="0.5" Foreground="{DynamicResource ForegroundColor}"/>

                        <WrapPanel>
                            <Button Margin="0,0,8,8" Padding="10,8" CornerRadius="12"
                                    Command="{Binding SelectVerificationTemplateCommand}"
                                    CommandParameter="Workout">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="💪" FontFamily="{StaticResource EmojiFont}" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Workout" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Margin="0,0,8,8" Padding="10,8" CornerRadius="12"
                                    Command="{Binding SelectVerificationTemplateCommand}"
                                    CommandParameter="Meal">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="🍽️" FontFamily="{StaticResource EmojiFont}" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Meal" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Margin="0,0,8,8" Padding="10,8" CornerRadius="12"
                                    Command="{Binding SelectVerificationTemplateCommand}"
                                    CommandParameter="Workspace">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="💼" FontFamily="{StaticResource EmojiFont}" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Workspace" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Margin="0,0,8,8" Padding="10,8" CornerRadius="12"
                                    Command="{Binding SelectVerificationTemplateCommand}"
                                    CommandParameter="Reading">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="📖" FontFamily="{StaticResource EmojiFont}" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Reading" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Margin="0,0,8,8" Padding="10,8" CornerRadius="12"
                                    Command="{Binding SelectVerificationTemplateCommand}"
                                    CommandParameter="Outdoors">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="🌿" FontFamily="{StaticResource EmojiFont}" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Outdoors" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Margin="0,0,8,8" Padding="10,8" CornerRadius="12"
                                    Command="{Binding SelectVerificationTemplateCommand}"
                                    CommandParameter="Sleep">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="😴" FontFamily="{StaticResource EmojiFont}" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Sleep" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Margin="0,0,8,8" Padding="10,8" CornerRadius="12"
                                    Command="{Binding SelectVerificationTemplateCommand}"
                                    CommandParameter="Meditation">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="🧘" FontFamily="{StaticResource EmojiFont}" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Meditation" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Margin="0,0,8,8" Padding="10,8" CornerRadius="12"
                                    Command="{Binding SelectVerificationTemplateCommand}"
                                    CommandParameter="Cleaning">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="🧹" FontFamily="{StaticResource EmojiFont}" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Cleaning" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Margin="0,0,8,8" Padding="10,8" CornerRadius="12"
                                    Command="{Binding SelectVerificationTemplateCommand}"
                                    CommandParameter="Water">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="💧" FontFamily="{StaticResource EmojiFont}" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Water" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Margin="0,0,8,8" Padding="10,8" CornerRadius="12"
                                    Command="{Binding SelectVerificationTemplateCommand}"
                                    CommandParameter="ColdShower">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="🚿" FontFamily="{StaticResource EmojiFont}" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Cold Shower" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Margin="0,0,8,8" Padding="10,8" CornerRadius="12"
                                    Command="{Binding SelectVerificationTemplateCommand}"
                                    CommandParameter="Study">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="📚" FontFamily="{StaticResource EmojiFont}" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Study" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Margin="0,0,8,8" Padding="10,8" CornerRadius="12"
                                    Command="{Binding SelectVerificationTemplateCommand}"
                                    CommandParameter="Custom">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="✏️" FontFamily="{StaticResource EmojiFont}" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Custom" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>

                        <!-- Selected template indicator -->
                        <Border Background="#15FFFFFF" CornerRadius="8" Padding="10,6">
                            <TextBlock FontSize="12" Foreground="{DynamicResource ForegroundColor}" Opacity="0.8">
                                <Run Text="Selected: "/>
                                <Run Text="{Binding SelectedVerificationTemplate}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </Border>

                        <!-- Custom criteria input -->
                        <StackPanel IsVisible="{Binding IsCustomVerification}" Spacing="6">
                            <TextBlock Text="Custom Criteria" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundColor}"/>
                            <TextBox Text="{Binding CustomVerificationCriteria}"
                                     Watermark="Describe what the photo should show..."
                                     FontSize="13" AcceptsReturn="True" MaxHeight="100"/>
                        </StackPanel>
                    </StackPanel>
                </shad:Card>

                <!-- Color Palette -->
                <Panel>
                <shad:Card Padding="14" Background="{DynamicResource Brush.Card}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Color" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundColor}"/>
                        <ItemsControl ItemsSource="{x:Static vm:TaskEditorViewModel.AvailableColors}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Button Classes="Ghost" Padding="3" Margin="3"
                                            Width="36" Height="36"
                                            Command="{Binding ((vm:TaskEditorViewModel)DataContext).SelectColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Border Width="28" Height="28" CornerRadius="14"
                                                Background="{Binding Converter={StaticResource ColorConverter}}"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </shad:Card>
                <Border Classes="PulseLock" IsVisible="{Binding !CanCustomizeColors}"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,-4,-4,0" Width="28" Height="28" CornerRadius="14"
                        IsHitTestVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="#FFD54F" Offset="0"/>
                            <GradientStop Color="#FF9800" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="🔒" FontFamily="{StaticResource EmojiFont}" FontSize="12"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                </Panel>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom save bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource Brush.Background}"
                BorderBrush="#22FFFFFF" BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid ColumnDefinitions="*,12,*">
                <Button Grid.Column="0" Padding="12"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Background="#15FFFFFF" CornerRadius="12"
                        Command="{Binding CancelCommand}">
                    <TextBlock Text="Cancel" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundColor}" Opacity="0.7"/>
                </Button>
                <Button Grid.Column="2" Padding="12"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Background="#66BB6A" CornerRadius="12"
                        Command="{Binding SaveTaskCommand}"
                        IsEnabled="{Binding !IsSaving}">
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Center">
                        <PathIcon Data="{x:Static shad:Icons.Check}" Width="16" Height="16"
                                  Foreground="White"/>
                        <TextBlock Text="Save Task"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="White"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

    </Grid>
</UserControl>
