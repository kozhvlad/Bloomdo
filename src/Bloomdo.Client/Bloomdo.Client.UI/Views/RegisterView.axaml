<UserControl
    x:Class="Bloomdo.Client.UI.RegisterView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shad="clr-namespace:ShadUI;assembly=ShadUI"
    xmlns:viewModels="clr-namespace:Bloomdo.Client.Application.ViewModels;assembly=Bloomdo.Client.Application"
    d:DesignHeight="900"
    d:DesignWidth="400"
    x:DataType="viewModels:RegisterViewModel"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid
            Margin="24"
            RowDefinitions="Auto,*,Auto"
            Background="{DynamicResource Brush.Background}">

            <!-- Logo / Branding -->
            <StackPanel Grid.Row="0" Margin="0,32,0,0" Spacing="8">
                <TextBlock
                    FontSize="32"
                    FontWeight="Bold"
                    Foreground="{DynamicResource Brush.Foreground}"
                    HorizontalAlignment="Center"
                    Text="Create Account" />
                <TextBlock
                    FontSize="16"
                    Foreground="{DynamicResource Brush.Foreground.Subtle}"
                    HorizontalAlignment="Center"
                    Text="Join Bloomdo and start your journey"
                    TextWrapping="Wrap" />
            </StackPanel>

            <!-- Registration Form -->
            <shad:Card Grid.Row="1" Margin="0,32,0,0" VerticalAlignment="Top">
                <StackPanel Spacing="20">
                    <!-- Error Message -->
                    <Border
                        Background="#20EF4444"
                        BorderBrush="{DynamicResource DestructiveColor}"
                        BorderThickness="1"
                        CornerRadius="8"
                        IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Padding="12">
                        <TextBlock
                            Foreground="{DynamicResource DestructiveColor}"
                            FontWeight="Medium"
                            Text="{Binding ErrorMessage}"
                            TextWrapping="Wrap" />
                    </Border>

                    <!-- Name Fields -->
                    <Grid ColumnDefinitions="*,16,*">
                        <TextBox
                            Grid.Column="0"
                            IsEnabled="{Binding !IsLoading}"
                            Text="{Binding FirstName, Mode=TwoWay}"
                            Watermark="John"
                            shad:ControlAssist.Label="First Name" />
                        <TextBox
                            Grid.Column="2"
                            IsEnabled="{Binding !IsLoading}"
                            Text="{Binding LastName, Mode=TwoWay}"
                            Watermark="Doe"
                            shad:ControlAssist.Label="Last Name" />
                    </Grid>

                    <!-- Email Input -->
                    <TextBox
                        Classes="Clearable"
                        IsEnabled="{Binding !IsLoading}"
                        Text="{Binding Email, Mode=TwoWay}"
                        Watermark="user@example.com"
                        shad:ControlAssist.Label="Email"
                        shad:ElementAssist.FocusOnLoad="True" />

                    <!-- Password Input -->
                    <TextBox
                        Classes="PasswordReveal"
                        IsEnabled="{Binding !IsLoading}"
                        PasswordChar="*"
                        Text="{Binding Password, Mode=TwoWay}"
                        Watermark="At least 6 characters"
                        shad:ControlAssist.Label="Password" />

                    <!-- Confirm Password Input -->
                    <TextBox
                        Classes="PasswordReveal"
                        IsEnabled="{Binding !IsLoading}"
                        PasswordChar="*"
                        Text="{Binding ConfirmPassword, Mode=TwoWay}"
                        Watermark="Re-enter your password"
                        shad:ControlAssist.Label="Confirm Password" />

                    <!-- Register Button -->
                    <Button
                        Classes="Primary"
                        Command="{Binding RegisterCommand}"
                        Height="48"
                        HorizontalAlignment="Stretch"
                        IsEnabled="{Binding !IsLoading}">
                        <TextBlock Text="Create Account" VerticalAlignment="Center" />
                    </Button>

                    <!-- Login Link -->
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="4">
                        <TextBlock
                            Foreground="{DynamicResource Brush.Foreground.Subtle}"
                            Text="Already have an account?"
                            VerticalAlignment="Center" />
                        <Button
                            Classes="Ghost"
                            Command="{Binding NavigateToLoginCommand}"
                            Content="Sign In"
                            Padding="4,2" />
                    </StackPanel>
                </StackPanel>
            </shad:Card>
        </Grid>
    </ScrollViewer>
</UserControl>
