<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shad="clr-namespace:ShadUI;assembly=ShadUI"
             xmlns:vms="clr-namespace:Bloomdo.Client.Application.ViewModels.MainComponents;assembly=Bloomdo.Client.Application"
             xmlns:dto="clr-namespace:Bloomdo.Shared.DTOs.Social;assembly=Bloomdo.Shared"
             xmlns:controls="clr-namespace:Bloomdo.Client.UI.Controls"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             x:DataType="vms:SocialViewModel"
             x:Class="Bloomdo.Client.UI.MainComponents.SocialView">

    <Grid RowDefinitions="Auto, *">

        <!-- Header -->
        <Border Grid.Row="0" Padding="20,48,20,16" Background="{DynamicResource Brush.Background}">
            <Grid ColumnDefinitions="*, Auto">
                <TextBlock Text="Social" FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource ForegroundLeadColor}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Command="{Binding ShowCreatePanelCommand}"
                        Classes="Primary"
                        Padding="16,8"
                        CornerRadius="20">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="{StaticResource add_regular}" Width="14" Height="14"
                                  Foreground="{DynamicResource PrimaryForegroundColor}"/>
                        <TextBlock Text="New Group" FontSize="13" Foreground="{DynamicResource PrimaryForegroundColor}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Loading bar -->
        <ProgressBar Grid.Row="0"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}"
                     VerticalAlignment="Bottom"
                     HorizontalAlignment="Stretch"
                     Height="3" Margin="0"/>

        <!-- Content -->
        <Grid Grid.Row="1">
            <ScrollViewer>
                <StackPanel Spacing="12" Margin="20,16,20,100">

                    <!-- Empty state -->
                    <StackPanel IsVisible="{Binding HasNoGroups}"
                                HorizontalAlignment="Center"
                                Margin="0,60,0,0"
                                Spacing="10">
                        <PathIcon Data="{StaticResource people_community_regular}"
                                  Width="56" Height="56"
                                  Opacity="0.2"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="No shared groups yet"
                                   FontSize="17" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Opacity="0.4"/>
                        <TextBlock Text="Create a group and invite your followers!"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   Opacity="0.3"/>
                    </StackPanel>

                    <!-- Groups list -->
                    <ItemsControl ItemsSource="{Binding Groups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="dto:SharedGroupDto">
                                <controls:SwipeRevealPanel Margin="0,0,0,10"
                                    HorizontalAlignment="Stretch"
                                    IsActionEnabled="{Binding IsOwner}"
                                    TapCommand="{Binding ((vms:SocialViewModel)DataContext).OpenGroupDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    TapCommandParameter="{Binding}"
                                    ActionCommand="{Binding ((vms:SocialViewModel)DataContext).DeleteGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    ActionCommandParameter="{Binding}"
                                    EditCommand="{Binding ((vms:SocialViewModel)DataContext).EditGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    EditCommandParameter="{Binding}">
                                    <shad:Card Padding="16,14">
                                        <Grid ColumnDefinitions="Auto, *, Auto">
                                            <!-- Group icon circle -->
                                            <Border Grid.Column="0"
                                                    Width="46" Height="46"
                                                    CornerRadius="12"
                                                    Background="{Binding Color}"
                                                    Margin="0,0,14,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Icon}"
                                                           FontFamily="{StaticResource EmojiFont}"
                                                           FontSize="22"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold" FontSize="15"/>
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <TextBlock FontSize="12" Opacity="0.6">
                                                        <Run Text="{Binding MembersCount}"/>
                                                        <Run Text="members"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="12" Opacity="0.6">
                                                        <Run Text="{Binding TasksCount}"/>
                                                        <Run Text="tasks"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Owner badge -->
                                            <Border Grid.Column="2"
                                                    IsVisible="{Binding IsOwner}"
                                                    Background="{DynamicResource PrimaryColor}"
                                                    CornerRadius="8"
                                                    Padding="8,4"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="Admin"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryForegroundColor}"/>
                                            </Border>
                                        </Grid>
                                    </shad:Card>
                                </controls:SwipeRevealPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Grid>

    </Grid>
</UserControl>
