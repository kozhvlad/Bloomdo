<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shad="clr-namespace:ShadUI;assembly=ShadUI"
             xmlns:vms="clr-namespace:Bloomdo.Client.Application.ViewModels.MainComponents;assembly=Bloomdo.Client.Application"
             xmlns:dto="clr-namespace:Bloomdo.Shared.DTOs.Social;assembly=Bloomdo.Shared"
             xmlns:converters="clr-namespace:Bloomdo.Client.UI.Converters"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             x:DataType="vms:FollowListViewModel"
             x:Class="Bloomdo.Client.UI.MainComponents.FollowListView">

    <UserControl.Resources>
        <converters:AvatarJsonToBrushConverter x:Key="AvatarJsonToBrush"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto, *">

        <!-- Header -->
        <Border Grid.Row="0" Padding="16,48,20,16" Background="{DynamicResource Brush.Background}">
            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="Auto, *">
                    <Button Grid.Column="0"
                            Command="{Binding GoBackCommand}"
                            Background="Transparent" BorderThickness="0"
                            Padding="4,8,12,8">
                        <PathIcon Data="{StaticResource arrow_left_regular}" Width="20" Height="20"/>
                    </Button>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Title}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource ForegroundLeadColor}"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Search & toolbar -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,-4,0,-8">
                    <TextBox Text="{Binding SearchText}"
                             Watermark="Search users..."
                             FontSize="13"/>
                    <Button Grid.Column="1" Classes="Ghost" Padding="8,6" Margin="4,0,0,0"
                            Command="{Binding ToggleSortCommand}">
                        <TextBlock Text="{Binding SortButtonText}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundColor}" Opacity="0.7"/>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Loading bar -->
        <ProgressBar Grid.Row="0"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}"
                     VerticalAlignment="Bottom"
                     HorizontalAlignment="Stretch"
                     Height="3" Margin="0"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="20,12,20,80" Spacing="8">

                <!-- Empty state -->
                <StackPanel IsVisible="{Binding !HasUsers}"
                            HorizontalAlignment="Center"
                            Margin="0,60,0,0"
                            Spacing="8">
                    <PathIcon Data="{StaticResource people_regular}"
                              Width="48" Height="48"
                              Opacity="0.2"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="No users yet"
                               FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Opacity="0.4"/>
                </StackPanel>

                <!-- Users list -->
                <ItemsControl ItemsSource="{Binding Users}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="dto:FollowStatusDto">
                            <shad:Card Margin="0,0,0,8" Padding="0">
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <!-- Tappable avatar + name area -->
                                    <Button Grid.Column="0" Grid.ColumnSpan="2"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="14,12" Cursor="Hand"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Command="{Binding $parent[UserControl].((vms:FollowListViewModel)DataContext).OpenProfileCommand}"
                                            CommandParameter="{Binding}">
                                        <Grid ColumnDefinitions="Auto, *">
                                            <Panel Grid.Column="0" Width="44" Height="44"
                                                   Margin="0,0,12,0" VerticalAlignment="Center">
                                                <!-- Letter fallback -->
                                                <Border Width="44" Height="44" CornerRadius="22"
                                                        Background="{DynamicResource PrimaryColor}"
                                                        IsVisible="{Binding User.AvatarJson, Converter={x:Static StringConverters.IsNullOrEmpty}}">
                                                    <TextBlock Text="{Binding User.Username[0]}"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontWeight="Bold"
                                                               FontSize="16"/>
                                                </Border>
                                                <!-- Mini avatar -->
                                                <Border Width="44" Height="44" CornerRadius="22" ClipToBounds="True"
                                                        IsVisible="{Binding User.AvatarJson, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                        Background="{Binding User.AvatarJson, Converter={StaticResource AvatarJsonToBrush}, ConverterParameter=Background}">
                                                    <Viewbox Width="38" Height="38" Stretch="Uniform"
                                                             VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                                             Margin="0,0,0,-4">
                                                        <Canvas Width="120" Height="120">
                                                            <Border Canvas.Left="34" Canvas.Top="72" Width="52" Height="48"
                                                                    CornerRadius="14,14,0,0"
                                                                    Background="{Binding User.AvatarJson, Converter={StaticResource AvatarJsonToBrush}, ConverterParameter=Clothing}"/>
                                                            <Border Canvas.Left="52" Canvas.Top="72" Width="16" Height="5"
                                                                    CornerRadius="0,0,8,8"
                                                                    Background="{Binding User.AvatarJson, Converter={StaticResource AvatarJsonToBrush}, ConverterParameter=Skin}"/>
                                                            <Border Canvas.Left="36" Canvas.Top="22" Width="48" Height="48"
                                                                    CornerRadius="24"
                                                                    Background="{Binding User.AvatarJson, Converter={StaticResource AvatarJsonToBrush}, ConverterParameter=Skin}"/>
                                                            <Border Canvas.Left="32" Canvas.Top="38" Width="10" Height="12"
                                                                    CornerRadius="5,0,0,5"
                                                                    Background="{Binding User.AvatarJson, Converter={StaticResource AvatarJsonToBrush}, ConverterParameter=Skin}"/>
                                                            <Border Canvas.Left="78" Canvas.Top="38" Width="10" Height="12"
                                                                    CornerRadius="0,5,5,0"
                                                                    Background="{Binding User.AvatarJson, Converter={StaticResource AvatarJsonToBrush}, ConverterParameter=Skin}"/>
                                                            <Border Canvas.Left="34" Canvas.Top="18" Width="52" Height="22"
                                                                    CornerRadius="26,26,4,4"
                                                                    Background="{Binding User.AvatarJson, Converter={StaticResource AvatarJsonToBrush}, ConverterParameter=Hair}"/>
                                                            <Border Canvas.Left="46" Canvas.Top="43" Width="8" Height="8" CornerRadius="4" Background="White"/>
                                                            <Border Canvas.Left="66" Canvas.Top="43" Width="8" Height="8" CornerRadius="4" Background="White"/>
                                                            <Border Canvas.Left="48" Canvas.Top="45" Width="5" Height="5" CornerRadius="2.5" Background="#1A1A1A"/>
                                                            <Border Canvas.Left="68" Canvas.Top="45" Width="5" Height="5" CornerRadius="2.5" Background="#1A1A1A"/>
                                                        </Canvas>
                                                    </Viewbox>
                                                </Border>
                                            </Panel>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                <TextBlock FontSize="15" FontWeight="SemiBold">
                                                    <Run Text="{Binding User.FirstName}"/>
                                                    <Run Text="{Binding User.LastName}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding User.Username, StringFormat='@{0}'}"
                                                           FontSize="13" Opacity="0.6"/>
                                            </StackPanel>
                                        </Grid>
                                    </Button>

                                    <!-- Follow/Unfollow button -->
                                    <Panel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,14,0">
                                        <Button IsVisible="{Binding IsFollowing}"
                                                Content="Unfollow"
                                                Classes="Outline"
                                                FontSize="12"
                                                Padding="12,6"
                                                Command="{Binding $parent[UserControl].((vms:FollowListViewModel)DataContext).UnfollowCommand}"
                                                CommandParameter="{Binding}"/>
                                        <Button IsVisible="{Binding !IsFollowing}"
                                                Content="Follow"
                                                Classes="Primary"
                                                FontSize="12"
                                                Padding="12,6"
                                                Command="{Binding $parent[UserControl].((vms:FollowListViewModel)DataContext).FollowCommand}"
                                                CommandParameter="{Binding}"/>
                                    </Panel>
                                </Grid>
                            </shad:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
