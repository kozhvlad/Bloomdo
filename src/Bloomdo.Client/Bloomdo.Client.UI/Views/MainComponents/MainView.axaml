<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:shad="clr-namespace:ShadUI;assembly=ShadUI"
			 xmlns:mainComponents1="clr-namespace:Bloomdo.Client.Application.ViewModels.MainComponents;assembly=Bloomdo.Client.Application"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:DataType="mainComponents1:MainViewModel"
			 x:Class="Bloomdo.Client.UI.MainComponents.MainView">
	
	<UserControl.Styles>
		<!-- Style for tab buttons -->
		<Style Selector="Button.TabButton">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Padding" Value="12,8"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
		</Style>
		
		<Style Selector="Button.TabButton:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent"/>
		</Style>
		
		<Style Selector="Button.TabButton:pressed /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent"/>
		</Style>
		
		<!-- Tab text styles -->
		<Style Selector="TextBlock.TabText">
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Foreground" Value="{DynamicResource ForegroundLeadColor}"/>
			<Setter Property="HorizontalAlignment" Value="Center"/>
		</Style>
		
		<Style Selector="TextBlock.TabText.Active">
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Foreground" Value="{DynamicResource ButtonForeground}"/>
		</Style>
		
		<!-- Tab icon styles -->
		<Style Selector="PathIcon.TabIcon">
			<Setter Property="Width" Value="24"/>
			<Setter Property="Height" Value="24"/>
			<Setter Property="Foreground" Value="{DynamicResource ForegroundLeadColor}"/>
			<Setter Property="HorizontalAlignment" Value="Center"/>
		</Style>
		
		<Style Selector="PathIcon.TabIcon.Active">
			<Setter Property="Foreground" Value="{DynamicResource ButtonForeground}"/>
		</Style>
	</UserControl.Styles>
	
	<Grid RowDefinitions="*,Auto" Background="{DynamicResource Brush.Background}">
		<!-- Main content area -->
		<ContentControl Grid.Row="0" 
						Content="{Binding CurrentPage}"
						HorizontalAlignment="Stretch"
						VerticalAlignment="Stretch"/>
		
		<!-- Bottom tab bar -->
		<Border Grid.Row="1" 
				Background="{DynamicResource Brush.Background}"
				BorderBrush="{DynamicResource OutlineColor}"
				BorderThickness="0,1,0,0"
				Padding="0,12,0,8">
			<Grid ColumnDefinitions="*,*,*,*,*,*">
				<!-- Home Tab -->
				<Button Grid.Column="0" 
						Classes="TabButton"
						Command="{Binding SelectTabCommand}"
						CommandParameter="0">
					<StackPanel Spacing="4" HorizontalAlignment="Center">
						<PathIcon Data="{StaticResource home_regular}"
								  Classes.Active="{Binding IsHomeSelected}"
								  Classes="TabIcon"/>
						<TextBlock Text="Home" 
								   Classes="TabText"
								   Classes.Active="{Binding IsHomeSelected}"/>
					</StackPanel>
				</Button>

				<!-- Blocks Tab -->
				<Button Grid.Column="1" 
						Classes="TabButton"
						Command="{Binding SelectTabCommand}"
						CommandParameter="1">
					<StackPanel Spacing="4" HorizontalAlignment="Center">
						<PathIcon Data="{StaticResource blocks_regular}"
								  Classes.Active="{Binding IsBlocksSelected}"
								  Classes="TabIcon"/>
						<TextBlock Text="Blocks" 
								   Classes="TabText"
								   Classes.Active="{Binding IsBlocksSelected}"/>
					</StackPanel>
				</Button>

				<!-- Stats Tab -->
				<Button Grid.Column="2" 
						Classes="TabButton"
						Command="{Binding SelectTabCommand}"
						CommandParameter="2">
					<StackPanel Spacing="4" HorizontalAlignment="Center">
						<PathIcon Data="{StaticResource stats_regular}"
								  Classes.Active="{Binding IsStatsSelected}"
								  Classes="TabIcon"/>
						<TextBlock Text="Stats" 
								   Classes="TabText"
								   Classes.Active="{Binding IsStatsSelected}"/>
					</StackPanel>
				</Button>

				<!-- AI Tab -->
				<Button Grid.Column="3" 
						Classes="TabButton"
						Command="{Binding SelectTabCommand}"
						CommandParameter="3">
					<StackPanel Spacing="4" HorizontalAlignment="Center">
						<PathIcon Data="{StaticResource chat_regular}"
								  Classes.Active="{Binding IsAiChatSelected}"
								  Classes="TabIcon"/>
						<TextBlock Text="AI" 
								   Classes="TabText"
								   Classes.Active="{Binding IsAiChatSelected}"/>
					</StackPanel>
				</Button>

				<!-- Plus Tab -->
				<Button Grid.Column="4" 
						Classes="TabButton"
						Command="{Binding SelectTabCommand}"
						CommandParameter="4">
					<StackPanel Spacing="4" HorizontalAlignment="Center">
						<PathIcon Data="{StaticResource star_regular}"
								  Classes.Active="{Binding IsSubscriptionSelected}"
								  Classes="TabIcon"/>
						<TextBlock Text="Plus" 
								   Classes="TabText"
								   Classes.Active="{Binding IsSubscriptionSelected}"/>
					</StackPanel>
				</Button>

				<!-- Profile Tab -->
				<Button Grid.Column="5" 
						Classes="TabButton"
						Command="{Binding SelectTabCommand}"
						CommandParameter="5">
					<StackPanel Spacing="4" HorizontalAlignment="Center">
						<PathIcon Data="{StaticResource profile_regular}"
								  Classes.Active="{Binding IsProfileSelected}"
								  Classes="TabIcon"/>
						<TextBlock Text="Profile" 
								   Classes="TabText"
								   Classes.Active="{Binding IsProfileSelected}"/>
					</StackPanel>
				</Button>
			</Grid>
		</Border>
	</Grid>
</UserControl>
