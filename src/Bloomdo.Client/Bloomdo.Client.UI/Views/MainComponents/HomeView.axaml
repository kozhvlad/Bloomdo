<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:shad="clr-namespace:ShadUI;assembly=ShadUI"
			 xmlns:converters="clr-namespace:Bloomdo.Client.UI.Converters"
			 xmlns:controls="clr-namespace:Bloomdo.Client.UI.Controls"
			 xmlns:mainComponents1="clr-namespace:Bloomdo.Client.Application.ViewModels.MainComponents;assembly=Bloomdo.Client.Application"
			 xmlns:items="clr-namespace:Bloomdo.Client.Application.ViewModels.Items;assembly=Bloomdo.Client.Application"
			 mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
			 x:DataType="mainComponents1:HomeViewModel"
			 x:Class="Bloomdo.Client.UI.MainComponents.HomeView">

	<UserControl.Resources>
		<converters:BlockTypeColorConverter x:Key="GroupColorConverter"/>
		<converters:CompletedToOpacityConverter x:Key="CompletedToOpacity"/>
		<converters:CompletedToCheckBrushConverter x:Key="CompletedToCheckBrush"/>
	</UserControl.Resources>

	<Grid Background="{DynamicResource Brush.Background}">
		<ScrollViewer>
			<StackPanel Margin="20,20,20,100" Spacing="16">

				<!-- Header row with + button -->
				<Grid ColumnDefinitions="*,Auto">
					<StackPanel Spacing="2">
						<TextBlock Text="{Binding WelcomeMessage}"
								   FontSize="26" FontWeight="Bold"
								   Foreground="#EFEFEF"/>
						<TextBlock Text="{Binding TodayDateText}"
								   FontSize="13"
								   Foreground="#EFEFEF"
								   Opacity="0.5"/>
					</StackPanel>
					<Button Grid.Column="1" Padding="0"
								Width="40" Height="40"
								VerticalAlignment="Top"
								HorizontalContentAlignment="Center"
								VerticalContentAlignment="Center"
								CornerRadius="20"
								Background="#66BB6A"
								Command="{Binding ShowAddGroupCommand}">
						<PathIcon Data="{x:Static shad:Icons.Cross}" Width="16" Height="16"
								  Foreground="White">
							<PathIcon.RenderTransform>
								<RotateTransform Angle="45"/>
							</PathIcon.RenderTransform>
						</PathIcon>
					</Button>
				</Grid>

				<!-- Daily Progress Card -->
				<shad:Card Padding="14" Background="{DynamicResource Brush.Card}">
					<StackPanel Spacing="8">
						<Grid ColumnDefinitions="*,Auto">
							<TextBlock Text="Daily Progress"
									   FontSize="15" FontWeight="SemiBold"
									   Foreground="#EFEFEF"/>
							<TextBlock Grid.Column="1"
									   Text="{Binding ProgressText}"
									   FontSize="15" FontWeight="Bold"
									   Foreground="#EFEFEF"/>
						</Grid>
						<Border Background="#22FFFFFF" CornerRadius="5" Height="10" ClipToBounds="True">
							<Border Background="#66BB6A" Height="10"
									HorizontalAlignment="Stretch"
									RenderTransformOrigin="0%,50%">
								<Border.RenderTransform>
									<ScaleTransform ScaleX="{Binding ProgressFraction}"/>
								</Border.RenderTransform>
							</Border>
						</Border>
					</StackPanel>
				</shad:Card>

				<!-- Loading indicator -->
				<StackPanel IsVisible="{Binding IsLoading}" HorizontalAlignment="Center" Margin="0,20">
					<TextBlock Text="Loading activities..."
							   FontSize="14" Opacity="0.5"
							   Foreground="#EFEFEF"
							   HorizontalAlignment="Center"/>
				</StackPanel>

				<!-- Empty state -->
				<StackPanel IsVisible="{Binding HasNoGroups}"
							Spacing="12" HorizontalAlignment="Center" Margin="0,40">
					<Border Width="64" Height="64" CornerRadius="32"
							Background="#22FFFFFF" HorizontalAlignment="Center">
						<PathIcon Data="{x:Static shad:Icons.Check}" Width="28" Height="28"
								  Foreground="#EFEFEF" Opacity="0.4"/>
					</Border>
					<TextBlock Text="No activities yet"
							   FontSize="17" FontWeight="SemiBold"
							   HorizontalAlignment="Center"
							   Foreground="#EFEFEF" Opacity="0.5"/>
					<TextBlock Text="Tap + to create your first group"
							   FontSize="13" HorizontalAlignment="Center"
							   Foreground="#EFEFEF" Opacity="0.35"/>
				</StackPanel>

				<!-- Activity Groups -->
				<ItemsControl ItemsSource="{Binding Groups}">
					<ItemsControl.ItemTemplate>
						<DataTemplate x:DataType="items:ActivityGroupItemViewModel">
							<shad:Card Padding="0" Background="{DynamicResource Brush.Card}" Margin="0,0,0,10">
								<StackPanel>
									<!-- Group Header -->
									<Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="14,10">
										<!-- Group icon badge -->
										<Border Grid.Column="0" Width="36" Height="36"
												CornerRadius="18"
												Background="{Binding Color, Converter={StaticResource GroupColorConverter}}"
												VerticalAlignment="Center" Margin="0,0,10,0">
											<TextBlock Text="{Binding Icon}"
													   FontFamily="{StaticResource EmojiFont}"
													   FontSize="18"
													   HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>

										<!-- Title / Edit Mode -->
										<Panel Grid.Column="1" VerticalAlignment="Center">
											<StackPanel IsVisible="{Binding !IsEditing}" Spacing="1">
												<TextBlock Text="{Binding Title}"
														   FontSize="17" FontWeight="SemiBold"
														   Foreground="#EFEFEF"/>
												<StackPanel Orientation="Horizontal" Spacing="6">
													<TextBlock Text="{Binding ProgressText}"
															   FontSize="11" Opacity="0.5"
															   Foreground="#EFEFEF"/>
													<StackPanel Orientation="Horizontal" Spacing="2"
																	IsVisible="{Binding HasStreak}">
														<TextBlock Text="🔥"
																   FontSize="11"
																   Foreground="#FF9800"
																   FontFamily="{StaticResource EmojiFont}" />
														<TextBlock Text="{Binding StreakText}"
																   FontSize="11" FontWeight="SemiBold"
																   Foreground="#FF9800"/>
													</StackPanel>
												</StackPanel>
											</StackPanel>

											<StackPanel IsVisible="{Binding IsEditing}" Orientation="Horizontal" Spacing="8">
												<TextBox Text="{Binding EditTitle}"
														 FontSize="15" MinWidth="140"/>
												<Button Classes="Ghost" Padding="4"
														Command="{Binding $parent[ItemsControl].((mainComponents1:HomeViewModel)DataContext).ConfirmEditGroupCommand}"
														CommandParameter="{Binding}">
													<PathIcon Data="{x:Static shad:Icons.Check}" Width="16" Height="16"
															  Foreground="#66BB6A"/>
												</Button>
												<Button Classes="Ghost" Padding="4"
														Command="{Binding $parent[ItemsControl].((mainComponents1:HomeViewModel)DataContext).CancelEditGroupCommand}"
														CommandParameter="{Binding}">
													<PathIcon Data="{x:Static shad:Icons.Cross}" Width="16" Height="16"
															  Foreground="#EFEFEF" Opacity="0.5"/>
												</Button>
											</StackPanel>
										</Panel>

										<!-- Edit group -->
										<Button Grid.Column="2" Classes="Ghost" Padding="6"
												IsVisible="{Binding !IsEditing}"
												Command="{Binding $parent[ItemsControl].((mainComponents1:HomeViewModel)DataContext).StartEditGroupCommand}"
												CommandParameter="{Binding}">
											<PathIcon Data="{x:Static shad:Icons.Marker}" Width="14" Height="14"
													  Foreground="#EFEFEF" Opacity="0.4"/>
										</Button>

										<!-- Delete group -->
										<Button Grid.Column="3" Classes="Ghost" Padding="6"
												IsVisible="{Binding !IsEditing}"
												Command="{Binding $parent[ItemsControl].((mainComponents1:HomeViewModel)DataContext).DeleteGroupCommand}"
												CommandParameter="{Binding}">
											<PathIcon Data="{x:Static shad:Icons.Minus}" Width="14" Height="14"
													  Foreground="#EF5350"/>
										</Button>

										<!-- Expand/Collapse -->
										<Button Grid.Column="4" Classes="Ghost" Padding="6"
												Command="{Binding $parent[ItemsControl].((mainComponents1:HomeViewModel)DataContext).ToggleGroupExpandedCommand}"
												CommandParameter="{Binding}">
											<PathIcon Data="{x:Static shad:Icons.ChevronDown}" Width="14" Height="14"
													  Foreground="#EFEFEF" Opacity="0.4">
												<PathIcon.RenderTransform>
													<RotateTransform/>
												</PathIcon.RenderTransform>
											</PathIcon>
										</Button>
									</Grid>

									<!-- Color accent bar -->
									<Border Height="2"
											Background="{Binding Color, Converter={StaticResource GroupColorConverter}}"/>

									<!-- Tasks list (collapsible) -->
									<StackPanel IsVisible="{Binding IsExpanded}" Margin="10,6,10,10" Spacing="4">
										<ItemsControl ItemsSource="{Binding Tasks}">
											<ItemsControl.ItemTemplate>
												<DataTemplate x:DataType="items:ActivityTaskItemViewModel">
													<StackPanel Spacing="4">
														<!-- Swipe-to-delete+edit wrapper -->
														<controls:SwipeRevealPanel Margin="0,2"
															ActionCommand="{Binding ((mainComponents1:HomeViewModel)DataContext).DeleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
															ActionCommandParameter="{Binding}"
															EditCommand="{Binding ((mainComponents1:HomeViewModel)DataContext).StartEditItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
															EditCommandParameter="{Binding}">
															<!-- Activity card -->
															<Border CornerRadius="12" Padding="10,8"
																	Background="{Binding Color, Converter={StaticResource GroupColorConverter}}"
																	Opacity="{Binding IsCompleted, Converter={StaticResource CompletedToOpacity}}">
																<Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
																	<!-- Task icon circle -->
																	<Border Grid.Column="0"
																			Width="34" Height="34" CornerRadius="17"
																			Background="#33FFFFFF"
																			VerticalAlignment="Center" Margin="0,0,10,0">
																		<TextBlock Text="{Binding Icon}"
																				   FontFamily="{StaticResource EmojiFont}"
																				   FontSize="16"
																				   HorizontalAlignment="Center" VerticalAlignment="Center"/>
																	</Border>

																	<!-- Title + subtitle -->
																	<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
																		<TextBlock Text="{Binding Title}"
																				   FontSize="14" FontWeight="SemiBold"
																				   Foreground="White"/>
																		<TextBlock Text="{Binding Subtitle}"
																				   FontSize="10"
																				   Foreground="White" Opacity="0.75"/>
																	</StackPanel>

																	<!-- Streak badge -->
																	<Border Grid.Column="2"
																			IsVisible="{Binding HasStreak}"
																			Background="#33000000"
																			CornerRadius="9" Padding="5,2"
																			VerticalAlignment="Center" Margin="4,0">
																		<StackPanel Orientation="Horizontal" Spacing="2">
																			<TextBlock Text="{Binding StreakText}"
																					   FontSize="10" FontWeight="Bold"
																					   Foreground="White"/>
																		</StackPanel>
																	</Border>

																	<!-- Timer button (only for timer type with duration) -->
																	<Panel Grid.Column="3" VerticalAlignment="Center" Margin="2,0">
																		<Button Classes="Ghost" Padding="2"
																				IsVisible="{Binding HasDuration}"
																				Command="{Binding ((mainComponents1:HomeViewModel)DataContext).StartTimerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
																				CommandParameter="{Binding}">
																			<Border Width="28" Height="28" CornerRadius="14"
																					Background="#33FFFFFF">
																				<TextBlock Text="⏱️"
																						   FontFamily="{StaticResource EmojiFont}"
																						   FontSize="14"
																						   HorizontalAlignment="Center"
																						   VerticalAlignment="Center"/>
																			</Border>
																		</Button>
																		<!-- Count type controls -->
																		<StackPanel Orientation="Horizontal" Spacing="2"
																					IsVisible="{Binding IsCountType}"
																					VerticalAlignment="Center">
																			<Button Classes="Ghost" Padding="0"
																					Width="22" Height="22"
																					HorizontalContentAlignment="Center"
																					VerticalContentAlignment="Center"
																					Command="{Binding ((mainComponents1:HomeViewModel)DataContext).DecrementCountCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
																					CommandParameter="{Binding}">
																				<Border Width="20" Height="20" CornerRadius="10"
																						Background="#33FFFFFF">
																					<PathIcon Data="{x:Static shad:Icons.Minus}" Width="8" Height="8"
																							  Foreground="White"/>
																				</Border>
																			</Button>
																			<Border CornerRadius="6" Padding="4,1"
																					Background="#33000000" MinWidth="32"
																					VerticalAlignment="Center">
																				<TextBlock Text="{Binding CountProgressText}"
																						   FontSize="9" FontWeight="Bold"
																						   Foreground="White"
																						   HorizontalAlignment="Center"/>
																			</Border>
																			<Button Classes="Ghost" Padding="0"
																					Width="22" Height="22"
																					HorizontalContentAlignment="Center"
																					VerticalContentAlignment="Center"
																					Command="{Binding ((mainComponents1:HomeViewModel)DataContext).IncrementCountCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
																					CommandParameter="{Binding}">
																				<Border Width="20" Height="20" CornerRadius="10"
																						Background="#33FFFFFF">
																					<PathIcon Data="{x:Static shad:Icons.Cross}" Width="8" Height="8"
																							  Foreground="White">
																						<PathIcon.RenderTransform>
																							<RotateTransform Angle="45"/>
																						</PathIcon.RenderTransform>
																					</PathIcon>
																				</Border>
																			</Button>
																				</StackPanel>
																				<!-- Steps type controls -->
																				<StackPanel Orientation="Horizontal" Spacing="2"
																							IsVisible="{Binding IsStepsType}"
																							VerticalAlignment="Center">
																					<Button Classes="Ghost" Padding="0"
																							Width="22" Height="22"
																							HorizontalContentAlignment="Center"
																							VerticalContentAlignment="Center"
																							Command="{Binding ((mainComponents1:HomeViewModel)DataContext).DecrementStepsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
																							CommandParameter="{Binding}">
																						<Border Width="20" Height="20" CornerRadius="10"
																								Background="#33FFFFFF">
																							<PathIcon Data="{x:Static shad:Icons.Minus}" Width="8" Height="8"
																									  Foreground="White"/>
																						</Border>
																					</Button>
																					<Border CornerRadius="6" Padding="4,1"
																							Background="#33000000" MinWidth="44"
																							VerticalAlignment="Center">
																						<TextBlock Text="{Binding StepsProgressText}"
																								   FontSize="8" FontWeight="Bold"
																								   Foreground="White"
																								   HorizontalAlignment="Center"/>
																					</Border>
																					<Button Classes="Ghost" Padding="0"
																							Width="22" Height="22"
																							HorizontalContentAlignment="Center"
																							VerticalContentAlignment="Center"
																							Command="{Binding ((mainComponents1:HomeViewModel)DataContext).IncrementStepsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
																							CommandParameter="{Binding}">
																						<Border Width="20" Height="20" CornerRadius="10"
																								Background="#33FFFFFF">
																							<PathIcon Data="{x:Static shad:Icons.Cross}" Width="8" Height="8"
																									  Foreground="White">
																								<PathIcon.RenderTransform>
																									<RotateTransform Angle="45"/>
																								</PathIcon.RenderTransform>
																							</PathIcon>
																						</Border>
																					</Button>
																				</StackPanel>
																			</Panel>

																			<!-- Completion toggle -->
																	<Button Grid.Column="4"
																			Classes="Ghost" Padding="2"
																			VerticalAlignment="Center"
																			Command="{Binding ((mainComponents1:HomeViewModel)DataContext).ToggleTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
																			CommandParameter="{Binding}">
																		<Border Width="26" Height="26" CornerRadius="13"
																				Background="{Binding IsCompleted, Converter={StaticResource CompletedToCheckBrush}}"
																				BorderBrush="White" BorderThickness="2">
																			<Panel>
																				<PathIcon Data="{x:Static shad:Icons.Check}"
																						  Width="12" Height="12"
																						  Foreground="White"
																						  IsVisible="{Binding IsCompleted}"/>
																			</Panel>
																		</Border>
																	</Button>
																</Grid>
															</Border>
														</controls:SwipeRevealPanel>
													</StackPanel>
												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>

										<!-- Add activity button -->
										<Panel>
											<Button Classes="Ghost" Padding="8,6"
													HorizontalAlignment="Left"
													IsVisible="{Binding !IsAddingItem}"
													Command="{Binding $parent[ItemsControl].((mainComponents1:HomeViewModel)DataContext).ShowAddItemCommand}"
													CommandParameter="{Binding}">
												<StackPanel Orientation="Horizontal" Spacing="6">
													<PathIcon Data="{x:Static shad:Icons.Cross}" Width="11" Height="11"
															  Foreground="#EFEFEF" Opacity="0.35">
														<PathIcon.RenderTransform>
															<RotateTransform Angle="45"/>
														</PathIcon.RenderTransform>
													</PathIcon>
													<TextBlock Text="Add activity"
															   FontSize="12" Opacity="0.4"
															   Foreground="#EFEFEF"/>
												</StackPanel>
											</Button>

											<!-- Add item form -->
											<Border IsVisible="{Binding IsAddingItem}"
													Background="{DynamicResource Brush.Card}"
													CornerRadius="12" Padding="12" Margin="0,4"
													BorderBrush="#33FFFFFF" BorderThickness="1">
												<StackPanel Spacing="10">
													<TextBlock Text="New Activity"
															   FontSize="14" FontWeight="SemiBold"
															   Foreground="#EFEFEF"/>

													<TextBox Text="{Binding NewItemTitle}"
															 Watermark="Activity name..."
															 FontSize="13"/>

													<TextBox Text="{Binding NewItemDescription}"
																	 Watermark="Description (optional)"
																	 FontSize="12"/>

														<!-- Task type selector -->
														<StackPanel Spacing="4">
															<TextBlock Text="Type" FontSize="11" Opacity="0.5"
																	   Foreground="#EFEFEF"/>
															<Grid ColumnDefinitions="*,4,*" RowDefinitions="Auto,4,Auto">
																<Button Grid.Column="0" Grid.Row="0" Padding="8,6"
																		HorizontalAlignment="Stretch"
																		HorizontalContentAlignment="Center"
																		CornerRadius="8"
																		Command="{Binding $parent[ItemsControl].((mainComponents1:HomeViewModel)DataContext).SelectNewItemTaskTypeCommand}"
																		CommandParameter="Timer">
																	<StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
																		<TextBlock Text="⏱" FontFamily="{StaticResource EmojiFont}" FontSize="13" VerticalAlignment="Center"/>
																		<TextBlock Text="Timer" FontSize="11" FontWeight="SemiBold"
																				   Foreground="White" VerticalAlignment="Center"/>
																	</StackPanel>
																</Button>
																<Button Grid.Column="2" Grid.Row="0" Padding="8,6"
																		HorizontalAlignment="Stretch"
																		HorizontalContentAlignment="Center"
																		CornerRadius="8"
																		Command="{Binding $parent[ItemsControl].((mainComponents1:HomeViewModel)DataContext).SelectNewItemTaskTypeCommand}"
																		CommandParameter="Count">
																	<StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
																		<TextBlock Text="📊" FontFamily="{StaticResource EmojiFont}" FontSize="13" VerticalAlignment="Center"/>
																		<TextBlock Text="Count" FontSize="11" FontWeight="SemiBold"
																				   Foreground="White" VerticalAlignment="Center"/>
																	</StackPanel>
																</Button>
																<Button Grid.Column="0" Grid.Row="2" Padding="8,6"
																		HorizontalAlignment="Stretch"
																		HorizontalContentAlignment="Center"
																		CornerRadius="8"
																		Command="{Binding $parent[ItemsControl].((mainComponents1:HomeViewModel)DataContext).SelectNewItemTaskTypeCommand}"
																		CommandParameter="Steps">
																	<StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
																		<TextBlock Text="🚶" FontFamily="{StaticResource EmojiFont}" FontSize="13" VerticalAlignment="Center"/>
																		<TextBlock Text="Steps" FontSize="11" FontWeight="SemiBold"
																				   Foreground="White" VerticalAlignment="Center"/>
																	</StackPanel>
																</Button>
																<Button Grid.Column="2" Grid.Row="2" Padding="8,6"
																		HorizontalAlignment="Stretch"
																		HorizontalContentAlignment="Center"
																		CornerRadius="8"
																		Command="{Binding $parent[ItemsControl].((mainComponents1:HomeViewModel)DataContext).SelectNewItemTaskTypeCommand}"
																		CommandParameter="Checkbox">
																	<StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
																		<TextBlock Text="✅" FontFamily="{StaticResource EmojiFont}" FontSize="13" VerticalAlignment="Center"/>
																		<TextBlock Text="Checkbox" FontSize="11" FontWeight="SemiBold"
																				   Foreground="White" VerticalAlignment="Center"/>
																	</StackPanel>
																</Button>
															</Grid>
														</StackPanel>

														<!-- Duration stepper (Timer only) -->
														<Grid ColumnDefinitions="Auto,Auto,Auto,Auto"
															  IsVisible="{Binding IsNewItemTimerType}">
															<TextBlock Text="Duration:"
																	   FontSize="12" VerticalAlignment="Center"
																	   Foreground="#EFEFEF"
																	   Opacity="0.6" Margin="0,0,8,0"/>
															<Button Grid.Column="1" Classes="Ghost" Padding="6"
																	Width="32" Height="32"
																	HorizontalContentAlignment="Center"
																	VerticalContentAlignment="Center"
																	Command="{Binding $parent[ItemsControl].((mainComponents1:HomeViewModel)DataContext).DecrementNewItemDurationCommand}"
																	CommandParameter="{Binding}">
																<PathIcon Data="{x:Static shad:Icons.Minus}" Width="10" Height="10"
																		  Foreground="#EFEFEF"/>
															</Button>
															<Border Grid.Column="2" CornerRadius="6" Padding="10,4"
																	Background="#15FFFFFF" MinWidth="50"
																	HorizontalAlignment="Center">
																<TextBlock Text="{Binding NewItemDurationMinutes, StringFormat='{}{0} min'}"
																		   FontSize="13" FontWeight="SemiBold"
																		   Foreground="#EFEFEF"
																		   HorizontalAlignment="Center"/>
															</Border>
															<Button Grid.Column="3" Classes="Ghost" Padding="6"
																	Width="32" Height="32"
																	HorizontalContentAlignment="Center"
																	VerticalContentAlignment="Center"
																	Command="{Binding $parent[ItemsControl].((mainComponents1:HomeViewModel)DataContext).IncrementNewItemDurationCommand}"
																	CommandParameter="{Binding}">
																<PathIcon Data="{x:Static shad:Icons.Cross}" Width="10" Height="10"
																		  Foreground="#EFEFEF">
																	<PathIcon.RenderTransform>
																		<RotateTransform Angle="45"/>
																	</PathIcon.RenderTransform>
																</PathIcon>
															</Button>
														</Grid>

														<!-- Target count stepper (Count only) -->
														<Grid ColumnDefinitions="Auto,Auto,Auto,Auto"
															  IsVisible="{Binding IsNewItemCountType}">
															<TextBlock Text="Target:"
																	   FontSize="12" VerticalAlignment="Center"
																	   Foreground="#EFEFEF"
																	   Opacity="0.6" Margin="0,0,8,0"/>
															<Button Grid.Column="1" Classes="Ghost" Padding="6"
																	Width="32" Height="32"
																	HorizontalContentAlignment="Center"
																	VerticalContentAlignment="Center"
																	Command="{Binding $parent[ItemsControl].((mainComponents1:HomeViewModel)DataContext).DecrementNewItemTargetCountCommand}"
																	CommandParameter="{Binding}">
																<PathIcon Data="{x:Static shad:Icons.Minus}" Width="10" Height="10"
																		  Foreground="#EFEFEF"/>
															</Button>
															<Border Grid.Column="2" CornerRadius="6" Padding="10,4"
																	Background="#15FFFFFF" MinWidth="50"
																	HorizontalAlignment="Center">
																<TextBlock Text="{Binding NewItemTargetCount}"
																		   FontSize="13" FontWeight="SemiBold"
																		   Foreground="#EFEFEF"
																		   HorizontalAlignment="Center"/>
															</Border>
															<Button Grid.Column="3" Classes="Ghost" Padding="6"
																	Width="32" Height="32"
																	HorizontalContentAlignment="Center"
																	VerticalContentAlignment="Center"
																	Command="{Binding $parent[ItemsControl].((mainComponents1:HomeViewModel)DataContext).IncrementNewItemTargetCountCommand}"
																	CommandParameter="{Binding}">
																<PathIcon Data="{x:Static shad:Icons.Cross}" Width="10" Height="10"
																		  Foreground="#EFEFEF">
																	<PathIcon.RenderTransform>
																		<RotateTransform Angle="45"/>
																	</PathIcon.RenderTransform>
																</PathIcon>
															</Button>
														</Grid>

														<!-- Target steps stepper (Steps only) -->
														<Grid ColumnDefinitions="Auto,Auto,Auto,Auto"
															  IsVisible="{Binding IsNewItemStepsType}">
															<TextBlock Text="Goal:"
																	   FontSize="12" VerticalAlignment="Center"
																	   Foreground="#EFEFEF"
																	   Opacity="0.6" Margin="0,0,8,0"/>
															<Button Grid.Column="1" Classes="Ghost" Padding="6"
																	Width="32" Height="32"
																	HorizontalContentAlignment="Center"
																	VerticalContentAlignment="Center"
																	Command="{Binding $parent[ItemsControl].((mainComponents1:HomeViewModel)DataContext).DecrementNewItemTargetStepsCommand}"
																	CommandParameter="{Binding}">
																<PathIcon Data="{x:Static shad:Icons.Minus}" Width="10" Height="10"
																		  Foreground="#EFEFEF"/>
															</Button>
															<Border Grid.Column="2" CornerRadius="6" Padding="10,4"
																	Background="#15FFFFFF" MinWidth="60"
																	HorizontalAlignment="Center">
																<TextBlock Text="{Binding NewItemTargetCount, StringFormat='{}{0} steps'}"
																		   FontSize="11" FontWeight="SemiBold"
																		   Foreground="#EFEFEF"
																		   HorizontalAlignment="Center"/>
															</Border>
															<Button Grid.Column="3" Classes="Ghost" Padding="6"
																	Width="32" Height="32"
																	HorizontalContentAlignment="Center"
																	VerticalContentAlignment="Center"
																	Command="{Binding $parent[ItemsControl].((mainComponents1:HomeViewModel)DataContext).IncrementNewItemTargetStepsCommand}"
																	CommandParameter="{Binding}">
																<PathIcon Data="{x:Static shad:Icons.Cross}" Width="10" Height="10"
																		  Foreground="#EFEFEF">
																	<PathIcon.RenderTransform>
																		<RotateTransform Angle="45"/>
																	</PathIcon.RenderTransform>
																</PathIcon>
															</Button>
														</Grid>

													<!-- Color picker -->
													<StackPanel Spacing="3">
														<TextBlock Text="Color" FontSize="11" Opacity="0.5"
																   Foreground="#EFEFEF"/>
														<ItemsControl ItemsSource="{Binding ((mainComponents1:HomeViewModel)DataContext).AvailableColors, RelativeSource={RelativeSource AncestorType=UserControl}}">
															<ItemsControl.ItemsPanel>
																<ItemsPanelTemplate>
																	<WrapPanel/>
																</ItemsPanelTemplate>
															</ItemsControl.ItemsPanel>
															<ItemsControl.ItemTemplate>
																<DataTemplate x:DataType="x:String">
																	<Button Classes="Ghost" Padding="2" Margin="2"
																			Width="28" Height="28"
																			Command="{Binding ((mainComponents1:HomeViewModel)DataContext).SelectItemColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
																			CommandParameter="{Binding}">
																		<Border Width="22" Height="22" CornerRadius="11"
																				Background="{Binding Converter={StaticResource GroupColorConverter}}"/>
																	</Button>
																</DataTemplate>
															</ItemsControl.ItemTemplate>
														</ItemsControl>
													</StackPanel>

													<!-- Preview card -->
													<Border CornerRadius="10" Padding="8,6"
															Background="{Binding NewItemColor, Converter={StaticResource GroupColorConverter}}">
														<Grid ColumnDefinitions="Auto,*">
															<Border Width="28" Height="28" CornerRadius="14"
																	Background="#33FFFFFF" Margin="0,0,8,0">
																<TextBlock Text="{Binding NewItemIcon, FallbackValue='✨'}"
																		   FontFamily="{StaticResource EmojiFont}"
																		   FontSize="13"
																		   HorizontalAlignment="Center" VerticalAlignment="Center"/>
															</Border>
															<TextBlock Grid.Column="1"
																	   Text="{Binding NewItemTitle, FallbackValue='Preview'}"
																	   FontSize="13" FontWeight="SemiBold"
																	   Foreground="White" VerticalAlignment="Center"/>
														</Grid>
													</Border>

													<!-- Actions -->
													<Grid ColumnDefinitions="*,*" Margin="0,2,0,0">
														<Button Grid.Column="0" Classes="Ghost" Padding="8"
																HorizontalAlignment="Stretch"
																HorizontalContentAlignment="Center"
																Command="{Binding $parent[ItemsControl].((mainComponents1:HomeViewModel)DataContext).CancelAddItemCommand}"
																CommandParameter="{Binding}">
															<TextBlock Text="Cancel" FontSize="13"
																	   Foreground="#EFEFEF" Opacity="0.5"/>
														</Button>
														<Button Grid.Column="1" Padding="8"
																HorizontalAlignment="Stretch"
																HorizontalContentAlignment="Center"
																Background="#66BB6A" CornerRadius="8"
																Command="{Binding $parent[ItemsControl].((mainComponents1:HomeViewModel)DataContext).ConfirmAddItemCommand}"
																CommandParameter="{Binding}">
															<TextBlock Text="Add" FontSize="13" FontWeight="SemiBold"
																	   Foreground="White"/>
														</Button>
													</Grid>
												</StackPanel>
											</Border>
										</Panel>
									</StackPanel>
								</StackPanel>
							</shad:Card>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

				</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>
