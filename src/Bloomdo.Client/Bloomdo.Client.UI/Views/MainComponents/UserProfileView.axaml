<UserControl xmlns="https://github.com/avaloniaui"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:shad="clr-namespace:ShadUI;assembly=ShadUI"
 xmlns:converters="clr-namespace:Bloomdo.Client.UI.Converters"
 xmlns:mainComponents1="clr-namespace:Bloomdo.Client.Application.ViewModels.MainComponents;assembly=Bloomdo.Client.Application"
 mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="900"
 x:DataType="mainComponents1:UserProfileViewModel"
 x:Class="Bloomdo.Client.UI.MainComponents.UserProfileView">
<UserControl.Resources>
<converters:StringToBrushConverter x:Key="StringToBrush"/>
<converters:IntEqualConverter x:Key="IntEquals"/>
</UserControl.Resources>
<ScrollViewer>
<StackPanel Background="{DynamicResource GhostColor}" Spacing="0">
<Border Height="220" CornerRadius="0,0,24,24" ClipToBounds="True"
Background="{Binding AvatarBackgroundHex, Converter={StaticResource StringToBrush}}">
<Grid>
<Button Background="Transparent" BorderThickness="0" Padding="8" Cursor="Hand"
        HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12,12,0,0"
        Command="{Binding GoBackCommand}">
    <PathIcon Data="{x:Static shad:Icons.ChevronLeft}" Width="22" Height="22"
      Foreground="White" Opacity="0.9"/>
</Button>
<Viewbox Width="190" Height="190" Stretch="Uniform"
         VerticalAlignment="Bottom" HorizontalAlignment="Center">
        <Canvas Width="120" Height="120">
<!-- Body Type 0: Slim -->
<Border Canvas.Left="38" Canvas.Top="72" Width="44" Height="48"
CornerRadius="12,12,0,0"
Background="{Binding AvatarClothingHex, Converter={StaticResource StringToBrush}}"
IsVisible="{Binding AvatarBodyType, Converter={StaticResource IntEquals}, ConverterParameter=0}"/>
<!-- Body Type 1: Average -->
<Border Canvas.Left="34" Canvas.Top="72" Width="52" Height="48"
CornerRadius="14,14,0,0"
Background="{Binding AvatarClothingHex, Converter={StaticResource StringToBrush}}"
IsVisible="{Binding AvatarBodyType, Converter={StaticResource IntEquals}, ConverterParameter=1}"/>
<!-- Body Type 2: Athletic -->
<Border Canvas.Left="30" Canvas.Top="72" Width="60" Height="48"
CornerRadius="16,16,0,0"
Background="{Binding AvatarClothingHex, Converter={StaticResource StringToBrush}}"
IsVisible="{Binding AvatarBodyType, Converter={StaticResource IntEquals}, ConverterParameter=2}"/>
<!-- Body Type 3: Broad -->
<Border Canvas.Left="26" Canvas.Top="72" Width="68" Height="48"
CornerRadius="18,18,0,0"
Background="{Binding AvatarClothingHex, Converter={StaticResource StringToBrush}}"
IsVisible="{Binding AvatarBodyType, Converter={StaticResource IntEquals}, ConverterParameter=3}"/>
<!-- Body Type 4: Muscular -->
<Border Canvas.Left="24" Canvas.Top="72" Width="72" Height="48"
CornerRadius="20,20,0,0"
Background="{Binding AvatarClothingHex, Converter={StaticResource StringToBrush}}"
IsVisible="{Binding AvatarBodyType, Converter={StaticResource IntEquals}, ConverterParameter=4}"/>
<!-- Clothing neckline: Style 0 T-Shirt -->
<Border Canvas.Left="52" Canvas.Top="72" Width="16" Height="5"
CornerRadius="0,0,8,8"
Background="{Binding AvatarSkinHex, Converter={StaticResource StringToBrush}}"
IsVisible="{Binding AvatarClothingStyle, Converter={StaticResource IntEquals}, ConverterParameter=0}"/>
<!-- Style 1: Hoodie -->
<Canvas Width="120" Height="120"
IsVisible="{Binding AvatarClothingStyle, Converter={StaticResource IntEquals}, ConverterParameter=1}">
<Border Canvas.Left="52" Canvas.Top="72" Width="16" Height="5"
CornerRadius="0,0,8,8"
Background="{Binding AvatarSkinHex, Converter={StaticResource StringToBrush}}"/>
<Border Canvas.Left="46" Canvas.Top="72" Width="28" Height="4"
CornerRadius="4,4,0,0" Background="Black" Opacity="0.06"/>
</Canvas>
<!-- Style 2: Shirt (V-neck) -->
<Border Canvas.Left="54" Canvas.Top="72" Width="12" Height="8"
CornerRadius="0,0,6,6"
Background="{Binding AvatarSkinHex, Converter={StaticResource StringToBrush}}"
IsVisible="{Binding AvatarClothingStyle, Converter={StaticResource IntEquals}, ConverterParameter=2}"/>
<!-- Style 3: Tank Top (wide neckline) -->
<Border Canvas.Left="48" Canvas.Top="72" Width="24" Height="5"
CornerRadius="0,0,12,12"
Background="{Binding AvatarSkinHex, Converter={StaticResource StringToBrush}}"
IsVisible="{Binding AvatarClothingStyle, Converter={StaticResource IntEquals}, ConverterParameter=3}"/>
<!-- Style 4: Sweater (high collar) -->
<Border Canvas.Left="50" Canvas.Top="72" Width="20" Height="4"
CornerRadius="3" Background="Black" Opacity="0.06"
IsVisible="{Binding AvatarClothingStyle, Converter={StaticResource IntEquals}, ConverterParameter=4}"/>
<Canvas Width="120" Height="120" IsVisible="{Binding AvatarHairStyle, Converter={StaticResource IntEquals}, ConverterParameter=2}">
<Border Canvas.Left="28" Canvas.Top="32" Width="14" Height="48"
CornerRadius="0,0,7,7"
Background="{Binding AvatarHairHex, Converter={StaticResource StringToBrush}}"/>
<Border Canvas.Left="78" Canvas.Top="32" Width="14" Height="48"
CornerRadius="0,0,7,7"
Background="{Binding AvatarHairHex, Converter={StaticResource StringToBrush}}"/>
</Canvas>
<Border Canvas.Left="36" Canvas.Top="22" Width="48" Height="48"
CornerRadius="24"
Background="{Binding AvatarSkinHex, Converter={StaticResource StringToBrush}}"/>
<Border Canvas.Left="32" Canvas.Top="38" Width="10" Height="12"
CornerRadius="5,0,0,5"
Background="{Binding AvatarSkinHex, Converter={StaticResource StringToBrush}}"/>
<Border Canvas.Left="78" Canvas.Top="38" Width="10" Height="12"
CornerRadius="0,5,5,0"
Background="{Binding AvatarSkinHex, Converter={StaticResource StringToBrush}}"/>
<Border Canvas.Left="34" Canvas.Top="18" Width="52" Height="22"
CornerRadius="26,26,4,4"
Background="{Binding AvatarHairHex, Converter={StaticResource StringToBrush}}"
IsVisible="{Binding AvatarHairStyle, Converter={StaticResource IntEquals}, ConverterParameter=0}"/>
<Canvas Width="120" Height="120" IsVisible="{Binding AvatarHairStyle, Converter={StaticResource IntEquals}, ConverterParameter=1}">
<Border Canvas.Left="32" Canvas.Top="16" Width="56" Height="28"
CornerRadius="28,28,8,8"
Background="{Binding AvatarHairHex, Converter={StaticResource StringToBrush}}"/>
<Border Canvas.Left="30" Canvas.Top="32" Width="12" Height="18"
CornerRadius="0,0,6,6"
Background="{Binding AvatarHairHex, Converter={StaticResource StringToBrush}}"/>
<Border Canvas.Left="78" Canvas.Top="32" Width="12" Height="18"
CornerRadius="0,0,6,6"
