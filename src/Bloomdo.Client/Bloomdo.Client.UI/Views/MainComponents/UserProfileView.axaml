Background="{Binding AvatarHeadwearHex, Converter={StaticResource StringToBrush}}"/>
<Border Canvas.Left="40" Canvas.Top="8" Width="8" Height="10" CornerRadius="4,4,0,0"
Background="{Binding AvatarHeadwearHex, Converter={StaticResource StringToBrush}}"/>
<Border Canvas.Left="56" Canvas.Top="6" Width="8" Height="12" CornerRadius="4,4,0,0"
Background="{Binding AvatarHeadwearHex, Converter={StaticResource StringToBrush}}"/>
<Border Canvas.Left="72" Canvas.Top="8" Width="8" Height="10" CornerRadius="4,4,0,0"
Background="{Binding AvatarHeadwearHex, Converter={StaticResource StringToBrush}}"/>
</Canvas>
<Border Canvas.Left="32" Canvas.Top="28" Width="56" Height="5" CornerRadius="2"
Background="{Binding AvatarHeadwearHex, Converter={StaticResource StringToBrush}}"
IsVisible="{Binding AvatarHeadwearStyle, Converter={StaticResource IntEquals}, ConverterParameter=4}"/>
<Canvas Width="120" Height="120"
IsVisible="{Binding AvatarHeadwearStyle, Converter={StaticResource IntEquals}, ConverterParameter=5}">
<Border Canvas.Left="72" Canvas.Top="20" Width="10" Height="8" CornerRadius="5"
Background="{Binding AvatarHeadwearHex, Converter={StaticResource StringToBrush}}"/>
<Border Canvas.Left="78" Canvas.Top="22" Width="4" Height="4" CornerRadius="2"
Background="{Binding AvatarHeadwearHex, Converter={StaticResource StringToBrush}}" Opacity="0.7"/>
<Border Canvas.Left="78" Canvas.Top="20" Width="10" Height="8" CornerRadius="5"
Background="{Binding AvatarHeadwearHex, Converter={StaticResource StringToBrush}}"/>
</Canvas>
</Canvas>
</Viewbox>
</Grid>
</Border>
<!-- Profile info -->
<StackPanel Margin="24,12,24,0" Spacing="4" HorizontalAlignment="Center">
<TextBlock Text="{Binding Name}" FontSize="24" FontWeight="Bold"
   HorizontalAlignment="Center" Foreground="{DynamicResource ForegroundColor}"/>
<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
<TextBlock Text="{Binding Username}" Opacity="0.6" FontSize="14"
   Foreground="{DynamicResource ForegroundColor}"
   IsVisible="{Binding Username, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
<TextBlock Text="·" Opacity="0.4" FontSize="14"
   Foreground="{DynamicResource ForegroundColor}"
   IsVisible="{Binding Username, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
<TextBlock Text="{Binding JoinedDateText}" Opacity="0.5" FontSize="14"
   Foreground="{DynamicResource ForegroundColor}"/>
</StackPanel>
<TextBlock Text="{Binding Bio}" FontSize="13" Opacity="0.6"
   HorizontalAlignment="Center" TextWrapping="Wrap"
   Foreground="{DynamicResource ForegroundColor}" Margin="0,4,0,0"
   IsVisible="{Binding Bio, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
<!-- Level badge (non-premium) -->
<shad:Badge Classes="Secondary" HorizontalAlignment="Center" Margin="0,8,0,0"
            IsVisible="{Binding !IsPremium}">
    <TextBlock Text="{Binding Level}" FontSize="12"/>
</shad:Badge>
<!-- Premium gradient badge -->
<Border IsVisible="{Binding IsPremium}"
        CornerRadius="14" Padding="14,6"
        HorizontalAlignment="Center" Margin="0,8,0,0">
    <Border.Background>
        <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
            <GradientStop Color="#7C3AED" Offset="0"/>
            <GradientStop Color="#A855F7" Offset="0.3"/>
            <GradientStop Color="#EC4899" Offset="0.65"/>
            <GradientStop Color="#F59E0B" Offset="1"/>
        </LinearGradientBrush>
    </Border.Background>
    <StackPanel Orientation="Horizontal" Spacing="5">
        <TextBlock Text="✦" FontSize="11" Foreground="White"
                   VerticalAlignment="Center" Opacity="0.9"/>
        <TextBlock Text="Bloomdo Plus" FontSize="12" FontWeight="SemiBold"
                   Foreground="White" LetterSpacing="0.3"/>
    </StackPanel>
</Border>
<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="24" Margin="0,14,0,0">
<StackPanel Orientation="Horizontal" Spacing="6">
<TextBlock Text="{Binding FollowersCount}" FontSize="16" FontWeight="Bold"
   Foreground="{DynamicResource ForegroundColor}"/>
<TextBlock Text="Followers" FontSize="14" Opacity="0.6"
   Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
</StackPanel>
<StackPanel Orientation="Horizontal" Spacing="6">
<TextBlock Text="{Binding FollowingCount}" FontSize="16" FontWeight="Bold"
   Foreground="{DynamicResource ForegroundColor}"/>
<TextBlock Text="Following" FontSize="14" Opacity="0.6"
   Foreground="{DynamicResource ForegroundColor}" VerticalAlignment="Center"/>
</StackPanel>
</StackPanel>
<!-- Relationship badge -->
<shad:Badge Classes="Outline" HorizontalAlignment="Center" Margin="0,8,0,0"
IsVisible="{Binding IsMutual}">
<TextBlock Text="Mutual" FontSize="11"/>
</shad:Badge>
</StackPanel>
<!-- Follow/Unfollow/Pending buttons -->
<StackPanel Margin="16,16,16,0" Spacing="8">
<Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
Padding="0,12" Height="48" CornerRadius="12" Classes="Primary" Cursor="Hand"
Foreground="#1A1A1A"
Command="{Binding FollowCommand}"
IsVisible="{Binding ShowFollowButton}">
<StackPanel Orientation="Horizontal" Spacing="8">
<PathIcon Data="{StaticResource add_regular}" Width="16" Height="16" Foreground="#1A1A1A"/>
<TextBlock Text="Follow" FontWeight="SemiBold" FontSize="14"
  VerticalAlignment="Center" Foreground="#1A1A1A"/>
</StackPanel>
</Button>
<Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
Padding="0,12" Height="48" CornerRadius="12" Classes="Outline" Cursor="Hand"
Command="{Binding UnfollowCommand}"
IsVisible="{Binding ShowUnfollowButton}">
<StackPanel Orientation="Horizontal" Spacing="8">
<PathIcon Data="{x:Static shad:Icons.Check}" Width="16" Height="16"
  Foreground="{DynamicResource ForegroundColor}"/>
<TextBlock Text="Following" FontWeight="SemiBold" FontSize="14"
  VerticalAlignment="Center" Foreground="{DynamicResource ForegroundColor}"/>
</StackPanel>
</Button>
<Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
Padding="0,12" Height="48" CornerRadius="12" Classes="Outline" Cursor="Hand"
IsEnabled="False"
IsVisible="{Binding ShowPendingButton}">
<StackPanel Orientation="Horizontal" Spacing="8">
<PathIcon Data="{x:Static shad:Icons.DateTime}" Width="16" Height="16"
  Foreground="{DynamicResource ForegroundColor}" Opacity="0.5"/>
<TextBlock Text="Pending" FontWeight="SemiBold" FontSize="14"
  VerticalAlignment="Center" Foreground="{DynamicResource ForegroundColor}" Opacity="0.5"/>
</StackPanel>
</Button>
</StackPanel>
<!-- Stats (visible only when CanViewStats) -->
<StackPanel IsVisible="{Binding CanViewStats}">
<Border Margin="16,20,16,0" CornerRadius="16" Padding="16,12"
BorderThickness="1" BorderBrush="{DynamicResource OutlineColor}">
<Grid ColumnDefinitions="*,Auto,*,Auto,*">
<StackPanel Grid.Column="0" Spacing="2" HorizontalAlignment="Center">
<TextBlock Text="{Binding StreakDays}" FontSize="22" FontWeight="Bold"
   HorizontalAlignment="Center" Foreground="{DynamicResource ForegroundColor}"/>
<TextBlock Text="Day Streak" FontSize="11" Opacity="0.5"
   HorizontalAlignment="Center" Foreground="{DynamicResource ForegroundColor}"/>
</StackPanel>
<Border Grid.Column="1" Width="1" Background="{DynamicResource OutlineColor}" Margin="0,4"/>
<StackPanel Grid.Column="2" Spacing="2" HorizontalAlignment="Center">
<TextBlock Text="{Binding TasksCompleted}" FontSize="22" FontWeight="Bold"
   HorizontalAlignment="Center" Foreground="{DynamicResource ForegroundColor}"/>
<TextBlock Text="Tasks Done" FontSize="11" Opacity="0.5"
   HorizontalAlignment="Center" Foreground="{DynamicResource ForegroundColor}"/>
</StackPanel>
<Border Grid.Column="3" Width="1" Background="{DynamicResource OutlineColor}" Margin="0,4"/>
<StackPanel Grid.Column="4" Spacing="2" HorizontalAlignment="Center">
<TextBlock Text="{Binding FocusHours}" FontSize="22" FontWeight="Bold"
   HorizontalAlignment="Center" Foreground="{DynamicResource ForegroundColor}"/>
<TextBlock Text="Focus Hrs" FontSize="11" Opacity="0.5"
   HorizontalAlignment="Center" Foreground="{DynamicResource ForegroundColor}"/>
</StackPanel>
</Grid>
</Border>
<Grid ColumnDefinitions="*,*" Margin="16,16,16,0" RowDefinitions="Auto,Auto">
<Border Grid.Column="0" Grid.Row="0" Margin="4" CornerRadius="12"
BorderThickness="1" BorderBrush="{DynamicResource OutlineColor}" ClipToBounds="True">
<Grid ColumnDefinitions="6,*">
<Border Grid.Column="0" Background="#FF6B35"/>
<StackPanel Grid.Column="1" Spacing="4" Margin="12,14">
<StackPanel Orientation="Horizontal" Spacing="6">
<Border Width="24" Height="24" CornerRadius="12" Background="#FF6B35">
<PathIcon Data="{x:Static shad:Icons.Calendar}" Width="12" Height="12"
  Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
</Border>
<TextBlock Text="{Binding StreakDays}" FontSize="20" FontWeight="Bold"
   VerticalAlignment="Center" Foreground="{DynamicResource ForegroundColor}"/>
</StackPanel>
<TextBlock Text="Day Streak" FontSize="12" Opacity="0.5"
   Foreground="{DynamicResource ForegroundColor}"/>
</StackPanel>
</Grid>
</Border>
<Border Grid.Column="1" Grid.Row="0" Margin="4" CornerRadius="12"
BorderThickness="1" BorderBrush="{DynamicResource OutlineColor}" ClipToBounds="True">
<Grid ColumnDefinitions="6,*">
<Border Grid.Column="0" Background="#4CAF50"/>
<StackPanel Grid.Column="1" Spacing="4" Margin="12,14">
<StackPanel Orientation="Horizontal" Spacing="6">
<Border Width="24" Height="24" CornerRadius="12" Background="#4CAF50">
<PathIcon Data="{x:Static shad:Icons.Check}" Width="12" Height="12"
  Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
</Border>
<TextBlock Text="{Binding TasksCompleted}" FontSize="20" FontWeight="Bold"
   VerticalAlignment="Center" Foreground="{DynamicResource ForegroundColor}"/>
</StackPanel>
<TextBlock Text="Tasks Done" FontSize="12" Opacity="0.5"
   Foreground="{DynamicResource ForegroundColor}"/>
</StackPanel>
</Grid>
</Border>
<Border Grid.Column="0" Grid.Row="1" Margin="4" CornerRadius="12"
BorderThickness="1" BorderBrush="{DynamicResource OutlineColor}" ClipToBounds="True">
<Grid ColumnDefinitions="6,*">
<Border Grid.Column="0" Background="#42A5F5"/>
<StackPanel Grid.Column="1" Spacing="4" Margin="12,14">
<StackPanel Orientation="Horizontal" Spacing="6">
<Border Width="24" Height="24" CornerRadius="12" Background="#42A5F5">
<PathIcon Data="{x:Static shad:Icons.Marker}" Width="12" Height="12"
  Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
</Border>
<TextBlock Text="{Binding FocusHours}" FontSize="20" FontWeight="Bold"
   VerticalAlignment="Center" Foreground="{DynamicResource ForegroundColor}"/>
</StackPanel>
<TextBlock Text="Focus Hours" FontSize="12" Opacity="0.5"
   Foreground="{DynamicResource ForegroundColor}"/>
</StackPanel>
</Grid>
</Border>
<Border Grid.Column="1" Grid.Row="1" Margin="4" CornerRadius="12"
BorderThickness="1" BorderBrush="{DynamicResource OutlineColor}" ClipToBounds="True">
<Grid ColumnDefinitions="6,*">
<Border Grid.Column="0" Background="#AB47BC"/>
<StackPanel Grid.Column="1" Spacing="4" Margin="12,14">
<StackPanel Orientation="Horizontal" Spacing="6">
<Border Width="24" Height="24" CornerRadius="12" Background="#AB47BC">
<PathIcon Data="{x:Static shad:Icons.Success}" Width="12" Height="12"
  Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
</Border>
<TextBlock Text="{Binding AchievementsUnlocked}" FontSize="20" FontWeight="Bold"
   VerticalAlignment="Center" Foreground="{DynamicResource ForegroundColor}"/>
</StackPanel>
<TextBlock Text="Achievements" FontSize="12" Opacity="0.5"
   Foreground="{DynamicResource ForegroundColor}"/>
</StackPanel>
</Grid>
</Border>
</Grid>
</StackPanel>
<!-- Private profile message -->
<Border Margin="16,24,16,0" CornerRadius="16" Padding="24,32"
BorderThickness="1" BorderBrush="{DynamicResource OutlineColor}"
IsVisible="{Binding !CanViewStats}">
<StackPanel Spacing="8" HorizontalAlignment="Center">
<PathIcon Data="{StaticResource blocks_regular}" Width="32" Height="32"
  Foreground="{DynamicResource ForegroundColor}" Opacity="0.4"
  HorizontalAlignment="Center"/>
<TextBlock Text="This profile is private" FontSize="16" FontWeight="SemiBold"
   HorizontalAlignment="Center" Foreground="{DynamicResource ForegroundColor}"/>
<TextBlock Text="Follow this user to see their stats and activity."
   FontSize="13" Opacity="0.5" HorizontalAlignment="Center" TextWrapping="Wrap"
   Foreground="{DynamicResource ForegroundColor}" TextAlignment="Center"/>
</StackPanel>
</Border>
<StackPanel Margin="16,24,16,32" Spacing="8"/>
</StackPanel>
</ScrollViewer>
</UserControl>
