CornerRadius="30,30,6,6"
Background="{Binding AvatarHairHex, Converter={StaticResource StringToBrush}}"
IsVisible="{Binding AvatarHairStyle, Converter={StaticResource IntEquals}, ConverterParameter=2}"/>
<Canvas Width="120" Height="120" IsVisible="{Binding AvatarHairStyle, Converter={StaticResource IntEquals}, ConverterParameter=3}">
<Border Canvas.Left="28" Canvas.Top="12" Width="64" Height="34"
CornerRadius="32"
Background="{Binding AvatarHairHex, Converter={StaticResource StringToBrush}}"/>
<Border Canvas.Left="26" Canvas.Top="28" Width="14" Height="22"
CornerRadius="7"
Background="{Binding AvatarHairHex, Converter={StaticResource StringToBrush}}"/>
<Border Canvas.Left="80" Canvas.Top="28" Width="14" Height="22"
