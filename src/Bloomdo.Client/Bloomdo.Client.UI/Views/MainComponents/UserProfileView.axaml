CornerRadius="8,8,0,0"
Background="{Binding AvatarHairHex, Converter={StaticResource StringToBrush}}"
IsVisible="{Binding AvatarHairStyle, Converter={StaticResource IntEquals}, ConverterParameter=5}"/>
