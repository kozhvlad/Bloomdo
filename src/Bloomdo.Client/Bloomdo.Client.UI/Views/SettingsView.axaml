<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shad="clr-namespace:ShadUI;assembly=ShadUI"
             xmlns:vm="clr-namespace:Bloomdo.Client.Application.ViewModels;assembly=Bloomdo.Client.Application"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             x:DataType="vm:SettingsViewModel"
             x:Class="Bloomdo.Client.UI.SettingsView">

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource GhostColor}">

        <!-- Header -->
        <Grid Margin="16,12,16,0" ColumnDefinitions="*,Auto">
            <TextBlock Text="Settings" FontSize="20" FontWeight="Bold"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource ForegroundColor}"/>
            <Button Grid.Column="1" Command="{Binding DoneCommand}"
                    Background="Transparent" BorderThickness="0"
                    Padding="8" Cursor="Hand">
                <TextBlock Text="DONE" FontSize="15" FontWeight="Bold"
                           Foreground="#42A5F5"/>
            </Button>
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Margin="0,12,0,0">
            <StackPanel Margin="16,0,16,32" Spacing="24">

                <!-- Account Section -->
                <StackPanel Spacing="0">
                    <TextBlock Text="Account" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundColor}" Opacity="0.5"
                               Margin="4,0,0,8"/>
                    <Border CornerRadius="12"
                            BorderThickness="1" BorderBrush="{DynamicResource OutlineColor}"
                            ClipToBounds="True">
                        <StackPanel>
                            <!-- Profile -->
                            <Button Command="{Binding GoToProfileCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="16,14" Cursor="Hand"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Profile" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundColor}"
                                               VerticalAlignment="Center"/>
                                    <PathIcon Grid.Column="1"
                                              Data="{x:Static shad:Icons.ChevronRight}"
                                              Width="14" Height="14"
                                              Foreground="{DynamicResource ForegroundColor}" Opacity="0.4"/>
                                </Grid>
                            </Button>

                            <Border Height="1" Background="{DynamicResource OutlineColor}" Margin="16,0"/>

                            <!-- Notifications -->
                            <Border Padding="16,14">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Notifications" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundColor}"
                                               VerticalAlignment="Center"/>
                                    <ToggleSwitch Grid.Column="1"
                                                  IsChecked="{Binding NotificationsEnabled}"
                                                  OnContent="" OffContent=""
                                                  VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Height="1" Background="{DynamicResource OutlineColor}" Margin="16,0"/>

                            <!-- Dark Theme -->
                            <Border Padding="16,14">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Dark Theme" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundColor}"
                                               VerticalAlignment="Center"/>
                                    <ToggleSwitch Grid.Column="1"
                                                  IsChecked="{Binding IsDarkTheme}"
                                                  OnContent="" OffContent=""
                                                  VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Support Section -->
                <StackPanel Spacing="0">
                    <TextBlock Text="Support" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundColor}" Opacity="0.5"
                               Margin="4,0,0,8"/>
                    <Border CornerRadius="12"
                            BorderThickness="1" BorderBrush="{DynamicResource OutlineColor}"
                            ClipToBounds="True">
                        <StackPanel>
                            <!-- Help Center -->
                            <Button Command="{Binding OpenHelpCenterCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="16,14" Cursor="Hand"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Help Center" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundColor}"
                                               VerticalAlignment="Center"/>
                                    <PathIcon Grid.Column="1"
                                              Data="{x:Static shad:Icons.ChevronRight}"
                                              Width="14" Height="14"
                                              Foreground="{DynamicResource ForegroundColor}" Opacity="0.4"/>
                                </Grid>
                            </Button>

                            <Border Height="1" Background="{DynamicResource OutlineColor}" Margin="16,0"/>

                            <!-- Feedback -->
                            <Button Command="{Binding OpenFeedbackCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="16,14" Cursor="Hand"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Feedback" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundColor}"
                                               VerticalAlignment="Center"/>
                                    <PathIcon Grid.Column="1"
                                              Data="{x:Static shad:Icons.ChevronRight}"
                                              Width="14" Height="14"
                                              Foreground="{DynamicResource ForegroundColor}" Opacity="0.4"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Sign Out -->
                <Button Command="{Binding LogoutCommand}"
                        Background="Transparent" BorderThickness="1"
                        BorderBrush="#EF5350"
                        CornerRadius="12" Padding="0,14"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Cursor="Hand">
                    <TextBlock Text="SIGN OUT" FontSize="15" FontWeight="Bold"
                               Foreground="#EF5350"
                               HorizontalAlignment="Center"/>
                </Button>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
